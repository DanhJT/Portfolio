---
const { pathname } = Astro.url;
const isActive = (href: string) => {
  if (href === "/") return pathname === "/";
  return pathname.startsWith(href);
};
const links = [
  { href: "/", label: "Home" },
  { href: "/about", label: "About" },
  { href: "/projects", label: "Projects" },
  { href: "/contact", label: "Contact" },
];
---

<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="brand">
      <span class="brand-name">Jan Tran</span>
      <span class="brand-sub">MSc Business · Finance</span>
    </a>
    <nav aria-label="Primary">
      <ul>
        {links.map((l) => (
          <li>
            <a href={l.href} class={isActive(l.href) ? "active" : ""}>{l.label}</a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    background: var(--color-surface);
    border-bottom: 1px solid var(--color-line);
    position: sticky;
    top: 0;
    z-index: 50;
    backdrop-filter: saturate(180%) blur(6px);
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    min-height: 72px;
    gap: 1rem;
  }
  .brand {
    display: flex;
    flex-direction: column;
    color: var(--color-ink);
    line-height: 1.1;
  }
  .brand:hover { color: var(--color-ink); }
  .brand-name {
    font-family: var(--font-serif);
    font-size: 1.2rem;
    font-weight: 500;
    letter-spacing: -0.005em;
  }
  .brand-sub {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-muted);
    margin-top: 2px;
  }
  nav ul {
    list-style: none;
    display: flex;
    gap: 1.75rem;
    margin: 0;
    padding: 0;
  }
  nav a {
    font-size: 0.9rem;
    color: var(--color-charcoal);
    padding: 0.25rem 0;
    position: relative;
  }
  nav a.active {
    color: var(--color-navy);
  }
  nav a.active::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: -4px;
    height: 1px;
    background: var(--color-navy);
  }
  @media (max-width: 560px) {
    .header-inner { flex-direction: column; align-items: flex-start; padding-top: 0.8rem; padding-bottom: 0.8rem; }
    nav ul { gap: 1.1rem; }
    .brand-sub { display: none; }
  }
</style>
