---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-left">
      <p class="name">Jan Tran</p>
      <p class="muted small">MSc Business · Finance</p>
    </div>
    <div class="footer-right">
      <a href="mailto:tran.jd@hotmail.com">tran.jd@hotmail.com</a>
      <a href="https://www.linkedin.com/in/jan-tran-054a60331/" target="_blank" rel="noopener">LinkedIn</a>
      <a href="tel:+4746779614">+47 467 79 614</a>
    </div>
  </div>
  <div class="container">
    <p class="copyright muted small">© {year} Jan Tran. Built with Astro.</p>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--color-line);
    background: var(--color-surface);
    padding: 2.5rem 0 1.5rem;
    margin-top: 4rem;
  }
  .footer-inner {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 2rem;
    flex-wrap: wrap;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid var(--color-line);
  }
  .name {
    font-family: var(--font-serif);
    font-size: 1.05rem;
    margin: 0 0 0.15rem;
    color: var(--color-ink);
  }
  .small { font-size: 0.82rem; margin: 0; }
  .footer-right {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    align-items: flex-end;
    font-size: 0.88rem;
  }
  .copyright {
    margin: 1rem 0 0;
    font-size: 0.78rem;
  }
  @media (max-width: 560px) {
    .footer-right { align-items: flex-start; }
  }
</style>
