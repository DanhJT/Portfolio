---
import Layout from "../../layouts/Layout.astro";
import { getCollection, render, type CollectionEntry } from "astro:content";

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  return projects.map((p) => ({
    params: { slug: p.id },
    props: { entry: p },
  }));
}

interface Props {
  entry: CollectionEntry<"projects">;
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const d = entry.data;

// Layout rules:
// - 0 screenshots   → prose only
// - 1 screenshot    → side column beside prose, no lead, no exhibits
// - 2-3 screenshots → first as lead-shot full width; rest stacked in side column
// - 4+ screenshots  → first stays in side column beside prose; rest in exhibits grid below
const total = d.screenshots.length;
const useExhibits = total >= 4;
const lead = total >= 2 && total <= 3 ? d.screenshots[0] : null;
const sideShots =
  total === 1 ? d.screenshots :
  total >= 4 ? [d.screenshots[0]] :
  total >= 2 ? d.screenshots.slice(1) :
  [];
const exhibits = useExhibits ? d.screenshots.slice(1) : [];
const hasSide = sideShots.length > 0;
---

<Layout title={`${d.title}, Jan Tran`} description={d.summary}>
  <article>
    <header class="project-hero">
      <div class="container container-prose">
        <a href="/projects" class="back">← All projects</a>
        <div class="meta">
          {d.course && <span>{d.course}</span>}
          {d.date && <span>{d.date}</span>}
          {d.grade && <span class="grade">{d.grade.toLowerCase().includes("waiting") ? d.grade : `Grade: ${d.grade}`}</span>}
          <span class="group-tag">Group project</span>
        </div>
        <h1>{d.title}</h1>
        <p class="lede">{d.summary}</p>
        <dl class="facts">
          {d.tools.length > 0 && (
            <>
              <dt>Tools</dt>
              <dd>{d.tools.join(" · ")}</dd>
            </>
          )}
          {d.tags.length > 0 && (
            <>
              <dt>Topics</dt>
              <dd>{d.tags.join(" · ")}</dd>
            </>
          )}
        </dl>
      </div>
    </header>

    {lead && (
      <section class="lead-shot">
        <div class="container">
          <figure>
            <img src={lead.src} alt={lead.alt} loading="lazy" class="lightbox-trigger" />
            {lead.caption && <figcaption>{lead.caption}</figcaption>}
          </figure>
        </div>
      </section>
    )}

    <section class="body">
      <div class="container">
        <div class={hasSide ? "body-grid" : "body-single"}>
          <div class="prose">
            <Content />
          </div>
          {hasSide && (
            <aside class="side-shots">
              {sideShots.map((s) => (
                <figure>
                  <img src={s.src} alt={s.alt} loading="lazy" class="lightbox-trigger" />
                  {s.caption && <figcaption>{s.caption}</figcaption>}
                </figure>
              ))}
            </aside>
          )}
        </div>
      </div>
    </section>

    {exhibits.length > 0 && (
      <section class="exhibits">
        <div class="container">
          <h2 class="exhibits-title">Exhibits</h2>
          <div class="exhibits-grid">
            {exhibits.map((s) => (
              <figure>
                <img src={s.src} alt={s.alt} loading="lazy" class="lightbox-trigger" />
                {s.caption && <figcaption>{s.caption}</figcaption>}
              </figure>
            ))}
          </div>
        </div>
      </section>
    )}

    <div class="container project-footer">
      <a href="/projects" class="btn">← Back to all projects</a>
    </div>
  </article>

  <!-- Lightbox overlay -->
  <div id="lightbox" aria-hidden="true" aria-modal="true" role="dialog">
    <button id="lightbox-close" aria-label="Close image">&times;</button>
    <img id="lightbox-img" src="" alt="" />
    <p id="lightbox-caption"></p>
  </div>
</Layout>

<style>
  .project-hero {
    padding: 4rem 0 2.5rem;
    border-bottom: 1px solid var(--color-line);
  }
  .back {
    display: inline-block;
    font-size: 0.85rem;
    color: var(--color-muted);
    margin-bottom: 1.5rem;
  }
  .back:hover { color: var(--color-navy); }
  .meta {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    align-items: center;
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-muted);
    margin-bottom: 1rem;
  }
  .grade { color: var(--color-navy); font-weight: 500; }
  .group-tag {
    padding: 0.2rem 0.6rem;
    border: 1px solid var(--color-line);
    border-radius: 999px;
    color: var(--color-charcoal);
    background: var(--color-surface);
    letter-spacing: 0.08em;
  }
  .facts {
    margin: 2rem 0 0;
    display: grid;
    grid-template-columns: 110px 1fr;
    row-gap: 0.55rem;
    column-gap: 1rem;
    font-size: 0.9rem;
    border-top: 1px solid var(--color-line);
    padding-top: 1.5rem;
  }
  .facts dt {
    color: var(--color-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.72rem;
    padding-top: 3px;
  }
  .facts dd { margin: 0; }

  .lead-shot {
    padding: 3.5rem 0 1rem;
    background: var(--color-surface);
    border-bottom: 1px solid var(--color-line);
  }
  .lead-shot figure { margin: 0; }
  .lead-shot img {
    display: block;
    width: 100%;
    height: auto;
    border: 1px solid var(--color-line);
    border-radius: var(--radius);
    background: #eef0f3;
  }
  .lead-shot figcaption {
    margin-top: 0.85rem;
    font-size: 0.85rem;
    color: var(--color-muted);
    text-align: center;
    font-style: italic;
  }

  .body {
    padding: 4rem 0 1rem;
  }
  .body-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.25fr) minmax(0, 1fr);
    gap: 4rem;
    align-items: start;
  }
  .body-single {
    max-width: 720px;
    margin: 0 auto;
  }
  .prose {
    font-size: 1rem;
    line-height: 1.75;
    color: var(--color-charcoal);
    min-width: 0;
  }
  .prose :global(h2) {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    margin-top: 2.25rem;
    margin-bottom: 0.75rem;
    color: var(--color-ink);
  }
  .prose :global(h2:first-child) { margin-top: 0; }
  .prose :global(h3) {
    font-size: 1.15rem;
    margin-top: 1.75rem;
  }
  .prose :global(p) { margin: 0 0 1.25em; }
  .prose :global(ul), .prose :global(ol) {
    margin: 0 0 1.25em 1.25rem;
    padding: 0;
  }
  .prose :global(li) { margin-bottom: 0.4em; }
  .prose :global(strong) { color: var(--color-ink); }

  .side-shots {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    min-width: 0;
  }
  .side-shots figure { margin: 0; }
  .side-shots img {
    display: block;
    width: 100%;
    height: auto;
    border: 1px solid var(--color-line);
    border-radius: var(--radius);
    background: #eef0f3;
  }
  .side-shots figcaption {
    margin-top: 0.6rem;
    font-size: 0.82rem;
    color: var(--color-muted);
    font-style: italic;
    line-height: 1.5;
  }

  .exhibits {
    padding: 4rem 0 1rem;
    border-top: 1px solid var(--color-line);
    margin-top: 3rem;
  }
  .exhibits-title {
    font-family: var(--font-serif);
    font-size: 1.6rem;
    margin: 0 0 2rem;
    color: var(--color-ink);
  }
  .exhibits-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2.5rem 2rem;
  }
  .exhibits-grid figure { margin: 0; }
  .exhibits-grid img {
    display: block;
    width: 100%;
    height: auto;
    border: 1px solid var(--color-line);
    border-radius: var(--radius);
    background: var(--color-bg);
  }
  .exhibits-grid figcaption {
    margin-top: 0.7rem;
    font-size: 0.85rem;
    color: var(--color-muted);
    font-style: italic;
    line-height: 1.5;
  }
  /* If there's an odd number of exhibits, center the orphan on its own row. */
  .exhibits-grid > figure:last-child:nth-child(odd) {
    grid-column: 1 / -1;
    max-width: calc(50% - 1rem);
    margin-left: auto;
    margin-right: auto;
  }

  .project-footer {
    padding: 3rem 1.5rem 4rem;
    max-width: var(--max-w-prose);
  }

  @media (max-width: 900px) {
    .body-grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
    .body { padding: 3rem 0 1rem; }
    .exhibits-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .exhibits-grid > figure:last-child:nth-child(odd) {
      max-width: 100%;
    }
  }

  /* Lightbox */
  .lightbox-trigger {
    cursor: zoom-in;
    transition: opacity 0.15s ease;
  }
  .lightbox-trigger:hover { opacity: 0.88; }

  #lightbox {
    position: fixed;
    inset: 0;
    background: rgba(10, 12, 18, 0.88);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    z-index: 999;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s ease;
  }
  #lightbox.is-open {
    opacity: 1;
    pointer-events: all;
  }
  #lightbox-img {
    max-width: min(90vw, 1200px);
    max-height: 80vh;
    width: auto;
    height: auto;
    border-radius: var(--radius);
    box-shadow: 0 30px 90px rgba(0, 0, 0, 0.6);
    display: block;
    transition: transform 0.2s ease;
  }
  #lightbox-caption {
    margin-top: 1.1rem;
    color: rgba(255, 255, 255, 0.65);
    font-size: 0.88rem;
    font-style: italic;
    text-align: center;
    max-width: 680px;
    line-height: 1.5;
  }
  #lightbox-close {
    position: fixed;
    top: 1.25rem;
    right: 1.75rem;
    background: none;
    border: none;
    color: rgba(255, 255, 255, 0.75);
    font-size: 2.2rem;
    line-height: 1;
    cursor: pointer;
    padding: 0.25rem 0.5rem;
    transition: color 0.15s;
  }
  #lightbox-close:hover { color: #fff; }
</style>

<script>
  const lightbox = document.getElementById('lightbox') as HTMLElement;
  const lbImg = document.getElementById('lightbox-img') as HTMLImageElement;
  const lbCaption = document.getElementById('lightbox-caption') as HTMLElement;
  const lbClose = document.getElementById('lightbox-close') as HTMLElement;

  function openLightbox(src: string, alt: string, caption: string) {
    lbImg.src = src;
    lbImg.alt = alt;
    lbCaption.textContent = caption;
    lightbox.classList.add('is-open');
    lightbox.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }

  function closeLightbox() {
    lightbox.classList.remove('is-open');
    lightbox.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  document.querySelectorAll<HTMLImageElement>('.lightbox-trigger').forEach((img) => {
    img.addEventListener('click', () => {
      const caption = img.closest('figure')?.querySelector('figcaption')?.textContent ?? '';
      openLightbox(img.src, img.alt, caption);
    });
  });

  lightbox.addEventListener('click', (e) => {
    if (e.target === lightbox) closeLightbox();
  });

  lbClose.addEventListener('click', closeLightbox);

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeLightbox();
  });
</script>
