---
import Layout from "../layouts/Layout.astro";
import ProjectCard from "../components/ProjectCard.astro";
import { getCollection } from "astro:content";

const projects = (await getCollection("projects")).sort(
  (a, b) => a.data.order - b.data.order,
);
const featured = projects.filter((p) => p.data.featured).slice(0, 3);
---

<Layout>
  <section class="hero">
    <div class="container hero-inner">
      <p class="eyebrow">Portfolio</p>
      <h1>Jan Tran</h1>
      <p class="role">MSc in Business, Major in Finance</p>
      <p class="lede pitch">
        Master's student at BI Norwegian Business School, majoring in Finance
        with a profile in Portfolio, Asset and Risk Management. Targeting a 2027
        graduate role in portfolio management, financial analysis, or valuation, where
        rigorous analysis meets the judgement to act on it.
      </p>
      <p class="currently">
        <span class="currently-label">Currently:</span> training for running
        and peak athleticism. Current priority: avoiding another injury arc.
      </p>
      <div class="cta">
        <a href="/projects" class="btn btn-primary">View projects</a>
        <a href="/about" class="btn">About me</a>
      </div>
    </div>
  </section>

  <hr class="divider" />

  <section class="section approach">
    <div class="container approach-inner">
      <div class="approach-head">
        <p class="eyebrow">Coding & AI</p>
        <h2>Smarter workflows,<br />better finance.</h2>
      </div>
      <div class="approach-body">
        <p>
          I have always been drawn to efficiency and technology. That is where my interest in AI and coding comes from. I believe that when AI is used well, it can help finance move faster, work smarter, and create more value by improving how information is processed, tested, and applied.
        </p>
        <p>
          My master's thesis explores machine learning in finance, giving me the chance to work directly with this intersection. Outside my studies, I am learning coding out of curiosity and a genuine interest in the technology shaping the next generation of financial work.
        </p>
      </div>
    </div>
  </section>

  <hr class="divider" />

  <section class="section">
    <div class="container">
      <div class="section-head">
        <div>
          <p class="eyebrow">Selected work</p>
          <h2>Featured projects</h2>
        </div>
        <a href="/projects" class="see-all">See all projects →</a>
      </div>
      <div class="grid">
        {featured.map((p) => (
          <ProjectCard
            href={`/projects/${p.id}`}
            title={p.data.title}
            summary={p.data.summary}
            course={p.data.course}
            grade={p.data.grade}
            tags={p.data.tags}
            cover={p.data.cover ?? p.data.screenshots[0]?.src}
            coverFit={p.data.coverFit}
          />
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
  .hero {
    padding: 6rem 0 4.5rem;
  }
  .hero-inner {
    max-width: 820px;
  }
  .role {
    font-family: var(--font-sans);
    font-size: 1.05rem;
    color: var(--color-navy);
    margin: -0.2rem 0 1.25rem;
    font-weight: 500;
    letter-spacing: 0.01em;
  }
  .pitch {
    max-width: 640px;
  }
  .currently {
    margin: 1.25rem 0 0;
    font-size: 0.95rem;
    color: var(--color-muted);
    font-style: italic;
    max-width: 640px;
  }
  .currently-label {
    color: var(--color-charcoal);
    font-style: normal;
    font-weight: 500;
    letter-spacing: 0.02em;
  }
  .cta {
    margin-top: 2rem;
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
  .section-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 2.5rem;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .see-all {
    font-size: 0.9rem;
    color: var(--color-navy);
    font-weight: 500;
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
  }
  .approach-inner {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.4fr);
    gap: 4rem;
    align-items: start;
  }
  .approach-head h2 {
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    line-height: 1.2;
    margin: 0;
  }
  .approach-body p {
    font-size: 1rem;
    line-height: 1.75;
    color: var(--color-charcoal);
    margin: 0;
  }
  .approach-body p + p { margin-top: 1.25em; }

  @media (max-width: 800px) {
    .approach-inner { grid-template-columns: 1fr; gap: 1.5rem; }
  }
  @media (max-width: 640px) {
    .hero { padding: 3.5rem 0 2.5rem; }
  }
</style>
