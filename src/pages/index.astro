---
import Layout from "../layouts/Layout.astro";
import ProjectCard from "../components/ProjectCard.astro";
import { getCollection } from "astro:content";

const projects = (await getCollection("projects")).sort(
  (a, b) => a.data.order - b.data.order,
);
const featured = projects.filter((p) => p.data.featured).slice(0, 3);
---

<Layout>
  <section class="hero">
    <div class="hero-glow" aria-hidden="true"></div>
    <div class="container hero-inner">
      <div class="hero-tag">
        <span class="tag-dot"></span>
        <span>Portfolio</span>
      </div>
      <h1>Jan Tran</h1>
      <div class="hero-line"></div>
      <p class="role">MSc in Business, Major in Finance</p>
      <p class="lede pitch">
        Master's student in Finance at BI Norwegian Business School, with a profile in Portfolio, Asset and Risk Management. I am drawn to work that combines analytical depth with practical impact, where finance, technology, and good judgement improve how decisions are made and how value is created.
      </p>
      <p class="currently">
        <span class="currently-label">Currently:</span> training for running
        and peak athleticism. Current priority: avoiding another injury arc.
      </p>
      <div class="cta">
        <a href="/projects" class="btn btn-primary">View projects</a>
        <a href="/about" class="btn">About me</a>
      </div>
    </div>
  </section>

  <hr class="divider" />

  <section class="section approach" data-animate>
    <div class="container">
      <div class="approach-card">
        <div class="approach-inner">
          <div class="approach-head">
            <p class="eyebrow">Coding & AI</p>
            <h2>Smarter workflows,<br />better finance.</h2>
          </div>
          <div class="approach-body">
            <p>
              I have always been drawn to efficiency and technology. That is where my interest in AI and coding comes from. I believe that when AI is used well, it can help finance move faster, work smarter, and create more value by improving how information is processed, tested, and applied.
            </p>
            <p>
              My master's thesis explores machine learning in finance, giving me the chance to work directly with this intersection. Outside my studies, I am learning coding out of curiosity and a genuine interest in the technology shaping the next generation of financial work.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <hr class="divider" />

  <section class="section" data-animate>
    <div class="container">
      <div class="section-head">
        <div>
          <p class="eyebrow">Selected work</p>
          <h2>Featured projects</h2>
        </div>
        <a href="/projects" class="see-all">See all projects →</a>
      </div>
      <div class="grid">
        {featured.map((p) => (
          <ProjectCard
            href={`/projects/${p.id}`}
            title={p.data.title}
            summary={p.data.summary}
            course={p.data.course}
            grade={p.data.grade}
            tags={p.data.tags}
            cover={p.data.cover ?? p.data.screenshots[0]?.src}
            coverFit={p.data.coverFit}
          />
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
  /* ── Hero ── */
  .hero {
    padding: 8rem 0 5.5rem;
    position: relative;
    overflow: hidden;
  }
  .hero-glow {
    position: absolute;
    top: -320px;
    left: -320px;
    width: 1000px;
    height: 1000px;
    background: radial-gradient(circle, rgba(22, 101, 52, 0.06) 0%, transparent 65%);
    pointer-events: none;
    z-index: 0;
  }
  .hero-inner {
    max-width: 860px;
    position: relative;
    z-index: 1;
  }
  .hero-tag {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    margin-bottom: 1.75rem;
    animation: fadeUp 0.55s ease both;
  }
  .tag-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--color-navy);
    animation: pulse 2.5s ease-in-out infinite;
  }
  .hero-tag span:last-child {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-muted);
    font-weight: 500;
  }
  .hero-inner h1 {
    animation: fadeUp 0.55s 0.1s ease both;
    margin-bottom: 0;
  }
  .hero-line {
    width: 52px;
    height: 2px;
    background: var(--color-navy);
    margin: 1.5rem 0 1.75rem;
    animation: fadeUp 0.55s 0.18s ease both;
  }
  .role {
    font-family: var(--font-sans);
    font-size: 1.05rem;
    color: var(--color-navy);
    margin: 0 0 1.25rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    animation: fadeUp 0.55s 0.25s ease both;
  }
  .pitch {
    max-width: 640px;
    animation: fadeUp 0.55s 0.33s ease both;
  }
  .currently {
    margin: 1.25rem 0 0;
    font-size: 0.95rem;
    color: var(--color-muted);
    font-style: italic;
    max-width: 640px;
    animation: fadeUp 0.55s 0.41s ease both;
  }
  .currently-label {
    color: var(--color-charcoal);
    font-style: normal;
    font-weight: 500;
    letter-spacing: 0.02em;
  }
  .cta {
    margin-top: 2.25rem;
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    animation: fadeUp 0.55s 0.5s ease both;
  }

  /* ── Scroll reveal ── */
  [data-animate] {
    opacity: 0;
    transform: translateY(28px);
    transition: opacity 0.65s ease, transform 0.65s ease;
  }
  [data-animate].is-visible {
    opacity: 1;
    transform: none;
  }

  /* ── Approach card ── */
  .approach-card {
    border: 1px solid var(--color-line);
    border-radius: 12px;
    padding: 3rem 3.5rem;
    background: rgba(255, 255, 255, 0.02);
    position: relative;
    overflow: hidden;
  }
  .approach-card::before {
    content: "";
    position: absolute;
    top: -120px;
    right: -120px;
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(22, 101, 52, 0.05) 0%, transparent 70%);
    pointer-events: none;
  }
  .approach-inner {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.4fr);
    gap: 4rem;
    align-items: start;
    position: relative;
  }
  .approach-head h2 {
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    line-height: 1.2;
    margin: 0;
  }
  .approach-body p {
    font-size: 1rem;
    line-height: 1.75;
    color: var(--color-charcoal);
    margin: 0;
  }
  .approach-body p + p { margin-top: 1.25em; }

  /* ── Featured projects ── */
  .section-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 2.5rem;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .see-all {
    font-size: 0.9rem;
    color: var(--color-navy);
    font-weight: 500;
    transition: opacity 0.15s ease;
  }
  .see-all:hover { opacity: 0.75; color: var(--color-navy); }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  /* ── Keyframes ── */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(18px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%       { opacity: 0.45; transform: scale(0.85); }
  }

  /* ── Responsive ── */
  @media (max-width: 800px) {
    .approach-inner { grid-template-columns: 1fr; gap: 1.5rem; }
    .approach-card  { padding: 2rem 1.75rem; }
  }
  @media (max-width: 640px) {
    .hero { padding: 4.5rem 0 3rem; }
  }
</style>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("is-visible");
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.12, rootMargin: "0px 0px -60px 0px" }
  );
  document.querySelectorAll("[data-animate]").forEach((el) => observer.observe(el));
</script>
