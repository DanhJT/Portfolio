---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Contact, Jan Tran">
  <section class="section">
    <div class="container contact-wrap">
      <p class="eyebrow">Contact</p>
      <h1>Get in touch.</h1>
      <p class="lede">
        Whether it is about a graduate role, an internship, a project, or
        just a conversation over coffee, I would be happy to hear from you.
        The easiest way to reach me is by email or LinkedIn, and I usually
        reply within a day.
      </p>

      <ul class="channels">
        <li>
          <span class="chan-label">Email</span>
          <a href="mailto:tran.jd@hotmail.com">tran.jd@hotmail.com</a>
        </li>
        <li>
          <span class="chan-label">LinkedIn</span>
          <a href="https://www.linkedin.com/in/jan-tran-054a60331/" target="_blank" rel="noopener">
            linkedin.com/in/jan-tran
          </a>
        </li>
        <li>
          <span class="chan-label">Phone</span>
          <a href="tel:+4746779614">+47 467 79 614</a>
        </li>
      </ul>
    </div>
  </section>
</Layout>

<style>
  .contact-wrap {
    max-width: 640px;
  }
  .channels {
    list-style: none;
    padding: 0;
    margin: 2rem 0 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    border-top: 1px solid var(--color-line);
    padding-top: 2rem;
  }
  .channels li {
    display: grid;
    grid-template-columns: 90px 1fr;
    align-items: baseline;
    gap: 1rem;
  }
  .chan-label {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-muted);
  }
  .channels a {
    font-size: 1rem;
    color: var(--color-ink);
  }
  .channels a:hover { color: var(--color-navy); }
</style>
